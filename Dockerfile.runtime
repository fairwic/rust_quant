# syntax=docker/dockerfile:1.7
FROM rust:1.91.1-bookworm AS builder

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends pkg-config libssl-dev ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY rust_quant ./rust_quant
COPY crypto_exc_all ./crypto_exc_all

WORKDIR /app/rust_quant
RUN --mount=type=cache,id=quant-core-cargo-registry,target=/usr/local/cargo/registry \
    --mount=type=cache,id=quant-core-cargo-git,target=/usr/local/cargo/git \
    --mount=type=cache,id=quant-core-target,target=/app/rust_quant/target \
    cargo build --release -p rust-quant-cli \
      --bin rust_quant \
      --bin quant_core_control_api \
      --bin quant_core_market_worker \
      --bin quant_core_signal_worker \
      --bin quant_core_account_worker \
      --bin quant_core_execution_worker \
      --bin quant_core_reconciliation_worker \
      --bin all_market_candle_volume_monitor \
      --bin market_velocity_candle_backfill \
      --bin market_velocity_kline_scanner \
      --bin market_velocity_event_backtest \
      --bin market_velocity_paper_observation \
      --bin market_velocity_live_handoff \
      --bin quant_core_schema_ensure \
    && mkdir -p /app/rust_quant/bin \
    && cp target/release/rust_quant /app/rust_quant/bin/rust_quant \
    && cp target/release/quant_core_control_api /app/rust_quant/bin/quant_core_control_api \
    && cp target/release/quant_core_market_worker /app/rust_quant/bin/quant_core_market_worker \
    && cp target/release/quant_core_signal_worker /app/rust_quant/bin/quant_core_signal_worker \
    && cp target/release/quant_core_account_worker /app/rust_quant/bin/quant_core_account_worker \
    && cp target/release/quant_core_execution_worker /app/rust_quant/bin/quant_core_execution_worker \
    && cp target/release/quant_core_reconciliation_worker /app/rust_quant/bin/quant_core_reconciliation_worker \
    && cp target/release/all_market_candle_volume_monitor /app/rust_quant/bin/all_market_candle_volume_monitor \
    && cp target/release/market_velocity_candle_backfill /app/rust_quant/bin/market_velocity_candle_backfill \
    && cp target/release/market_velocity_kline_scanner /app/rust_quant/bin/market_velocity_kline_scanner \
    && cp target/release/market_velocity_event_backtest /app/rust_quant/bin/market_velocity_event_backtest \
    && cp target/release/market_velocity_paper_observation /app/rust_quant/bin/market_velocity_paper_observation \
    && cp target/release/market_velocity_live_handoff /app/rust_quant/bin/market_velocity_live_handoff \
    && cp target/release/quant_core_schema_ensure /app/rust_quant/bin/quant_core_schema_ensure

FROM debian:bookworm-slim AS runtime

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates libssl3 curl \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/rust_quant/bin/rust_quant /usr/local/bin/rust_quant
COPY --from=builder /app/rust_quant/bin/quant_core_control_api /usr/local/bin/quant_core_control_api
COPY --from=builder /app/rust_quant/bin/quant_core_market_worker /usr/local/bin/quant_core_market_worker
COPY --from=builder /app/rust_quant/bin/quant_core_signal_worker /usr/local/bin/quant_core_signal_worker
COPY --from=builder /app/rust_quant/bin/quant_core_account_worker /usr/local/bin/quant_core_account_worker
COPY --from=builder /app/rust_quant/bin/quant_core_execution_worker /usr/local/bin/quant_core_execution_worker
COPY --from=builder /app/rust_quant/bin/quant_core_reconciliation_worker /usr/local/bin/quant_core_reconciliation_worker
COPY --from=builder /app/rust_quant/bin/all_market_candle_volume_monitor /usr/local/bin/all_market_candle_volume_monitor
COPY --from=builder /app/rust_quant/bin/market_velocity_candle_backfill /usr/local/bin/market_velocity_candle_backfill
COPY --from=builder /app/rust_quant/bin/market_velocity_kline_scanner /usr/local/bin/market_velocity_kline_scanner
COPY --from=builder /app/rust_quant/bin/market_velocity_event_backtest /usr/local/bin/market_velocity_event_backtest
COPY --from=builder /app/rust_quant/bin/market_velocity_paper_observation /usr/local/bin/market_velocity_paper_observation
COPY --from=builder /app/rust_quant/bin/market_velocity_live_handoff /usr/local/bin/market_velocity_live_handoff
COPY --from=builder /app/rust_quant/bin/quant_core_schema_ensure /usr/local/bin/quant_core_schema_ensure

ENV APP_ENV=production

CMD ["rust_quant"]
