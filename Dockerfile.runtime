FROM rust:1.91.1-bookworm AS builder

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends pkg-config libssl-dev ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY rust_quant ./rust_quant
COPY crypto_exc_all ./crypto_exc_all

WORKDIR /app/rust_quant
RUN cargo build --release -p rust-quant-cli --bins

FROM debian:bookworm-slim AS runtime

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates libssl3 curl \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/rust_quant/target/release/rust_quant /usr/local/bin/rust_quant
COPY --from=builder /app/rust_quant/target/release/market_velocity_candle_backfill /usr/local/bin/market_velocity_candle_backfill
COPY --from=builder /app/rust_quant/target/release/market_velocity_paper_observation /usr/local/bin/market_velocity_paper_observation
COPY --from=builder /app/rust_quant/target/release/market_velocity_live_handoff /usr/local/bin/market_velocity_live_handoff
COPY --from=builder /app/rust_quant/target/release/quant_core_schema_ensure /usr/local/bin/quant_core_schema_ensure

ENV APP_ENV=production

CMD ["rust_quant"]
