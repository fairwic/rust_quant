  "consumer_contracts": {
    "operator_playbook_summary": {
      "compatibility_contract_version": 1,
      "producer_required_paths": [
        "summary.operator_playbook_summary",
        "summary.operator_playbook_summary.item_count",
        "summary.operator_playbook_summary.blocking_item_count",
        "summary.operator_playbook_summary.manual_review_item_count",
        "summary.operator_playbook_summary.observe_only_item_count",
        "summary.operator_playbook_summary.items",
        "markdown.## Operator Playbook Summary",
        "admin_ingest.summary.operator_playbook_summary"
      ],
      "consumer_rules": [
        "Admin and CI must bind operator_playbook_summary.items before free-form Markdown text",
        "Consumers must ignore unknown appended operator_playbook_summary fields and item fields",
        "Dashboard counts must use item_count, blocking_item_count, manual_review_item_count, and observe_only_item_count"
      ]
    },
    "payment_entitlement_health_states": {
      "compatibility_contract_version": 1,
      "producer_required_paths": [
        "sections.payment_entitlement_health.skipped",
        "sections.payment_entitlement_health.query_failed",
        "sections.payment_entitlement_health.wallet_payment_exception_count",
        "sections.payment_entitlement_health.payment_entitlement_blocker_count",
        "summary.wallet_payment_exception_count",
        "summary.payment_entitlement_blocker_count"
      ],
      "states": [
        {
          "name": "skipped",
          "status": "warn",
          "source": "skipped",
          "read_only_input": false,
          "alert_code": "PAYMENT_INPUT_SKIPPED"
        },
        {
          "name": "query_failed",
          "status": "warn",
          "source": "quant_web_payment_readonly_db",
          "read_only_input": true,
          "alert_code": "PAYMENT_INPUT_QUERY_FAILED"
        },
        {
          "name": "real_count",
          "status": "ok|warn|fail",
          "source": "quant_web_payment_readonly_db",
          "read_only_input": true,
          "alert_code": "WALLET_PAYMENT_EXCEPTION|PAYMENT_ENTITLEMENT_BLOCKED"
        }
      ],
      "example_fixtures": [
        {
          "state": "skipped",
          "path": "docs/dev/full_product_health_examples/payment-entitlement-health-skipped.json"
        },
        {
          "state": "query_failed",
          "path": "docs/dev/full_product_health_examples/payment-entitlement-health-query-failed.json"
        },
        {
          "state": "real_count",
          "path": "docs/dev/full_product_health_examples/payment-entitlement-health-real-count.json"
        }
      ],
      "consumer_rules": [
        "skipped means no explicit read-only DB input was provided and must not be treated as zero incidents",
        "query_failed means explicit read-only DB input was provided but the query could not produce counts",
        "real_count means explicit read-only DB input produced wallet_payment_exception_count and payment_entitlement_blocker_count"
      ]
    },
    "payment_publish_index_read_only_consumption": {
      "compatibility_contract_version": 1,
      "producer_required_paths": [
        "publish_index.schemaVersion",
        "publish_index.storageStatus",
        "publish_index.stale",
        "publish_index.validation.status",
        "publish_index.redaction.status",
        "publish_index.summary.summary.wallet_payment_exception_count",
        "publish_index.summary.summary.payment_entitlement_blocker_count",
        "publish_index.summary.operator_playbook_summary.items"
      ],
      "consumer_rules": [
        "Admin and CI must read wallet_payment_exception_count and payment_entitlement_blocker_count from publish_index.summary.summary and must not re-query a database for these counters",
        "Missing wallet_payment_exception_count means unknown artifact drift and must not be displayed as zero incidents",
        "Admin and CI must bind publish_index.summary.operator_playbook_summary.items before free-form Markdown or log text",
        "The WALLET_PAYMENT_EXCEPTION playbook item must preserve default_next_action=review_wallet_payment_exceptions",
        "The PAYMENT_ENTITLEMENT_BLOCKED playbook item must preserve operator_action=block_release_until_resolved",
        "A publish index can be rendered as latest-ready only when storageStatus=current, stale=false, validation.status=ok, and redaction.status=ok"
      ]
    },
    "admin_latest_artifact_readiness_envelope": {
      "compatibility_contract_version": 1,
      "producer_required_paths": [
        "latest.ready",
        "latest.stale",
        "latest.staleReason",
        "latest.summary.summary.overall_status",
        "latest.summary.section_statuses",
        "latest.summary.checklist[].ready",
        "latest.summary.checklist[].action_required",
        "latest.summary.checklist[].live_readiness",
        "latest.summary.checklist[].manual_review_required",
        "latest.summary.required_operator_actions",
        "latest.summary.read_only_input_count",
        "latest.validation.status",
        "latest.validation.summary.sensitive_marker_count",
        "latest.redaction.status",
        "latest.paymentPublishIndex.status",
        "latest.paymentPublishIndex.readyToRender",
        "latest.walletPaymentConfig.source"
      ],
      "read_only_operator_surface": [
        "latest.ready",
        "latest.stale",
        "latest.staleReason",
        "latest.summary.section_statuses",
        "latest.summary.checklist",
        "latest.summary.operator_playbook_summary.items",
        "latest.paymentPublishIndex",
        "latest.walletPaymentConfig"
      ],
      "prohibited_automatic_actions": [
        "shell_out_from_admin_request",
        "read_env",
        "run_live_probe",
        "call_signed_exchange_endpoint",
        "lease_execution_task",
        "report_order_result",
        "mutate_execution_task",
        "place_order",
        "trigger_provider_recovery",
        "touch_protected_live_position"
      ],
      "consumer_rules": [
        "Admin must compute readiness from stored artifact fields only and must not use command exit code as readiness",
        "Missing latest readiness fields or paymentPublishIndex fields mean artifact drift or unknown, not ready",
        "paymentPublishIndex is a read-only display projection of the stored publish index",
        "readiness and paymentPublishIndex may render operator next-action labels but must not trigger recovery, task mutation, provider calls, or exchange calls automatically",
        "Only appended fields are allowed under compatibility_contract_version 1; removing or renaming any producer_required_paths entry requires a new compatibility_contract_version"
      ]
    },
    "admin_wallet_payment_config_env_snapshot": {
      "compatibility_contract_version": 1,
      "producer_required_paths": [
        "latest.walletPaymentConfig",
        "latest.walletPaymentConfig.source",
        "latest.walletPaymentConfig.source.kind",
        "latest.walletPaymentConfig.status",
        "latest.walletPaymentConfig.webWalletProviderReadiness"
      ],
      "source_values": [
        "admin_process_env_snapshot",
        "admin_managed_config_draft"
      ],
      "source_kind_allowed_values": [
        "admin_process_env_snapshot",
        "admin_managed_config_draft"
      ],
      "status_values": [
        "configured",
        "draft",
        "ready",
        "degraded",
        "unknown"
      ],
      "not_ready_cases": [
        "source_kind_missing_or_not_allowed_admin_config_source",
        "status_configured_without_web_wallet_provider_readiness",
        "status_draft",
        "status_degraded",
        "status_unknown",
        "web_wallet_provider_readiness_missing",
        "web_wallet_provider_readiness_unknown",
        "web_wallet_provider_readiness_incomplete",
        "web_wallet_provider_readiness_inconsistent_with_admin_snapshot"
      ],
      "consumer_rules": [
        "walletPaymentConfig.source.kind must be one of admin_process_env_snapshot or admin_managed_config_draft",
        "walletPaymentConfig is an Admin-only config snapshot or draft",
        "walletPaymentConfig must not represent Web wallet provider readiness",
        "If Web wallet readiness is missing or inconsistent, render degraded/unknown and not ready"
      ]
    }
  },
  "artifact_schemas": {
    "full_report": {
      "required_top_level": [
        "schema_version",
        "status",
        "generated_at",
        "summary",
        "sections",
        "alerts",
        "alert_taxonomy",
        "correlation"
      ],
      "required_summary_fields": [
        "p0_count",
        "p1_count",
        "info_count",
        "read_only_input_count"
      ],
      "append_only_paths": [
        "summary.*",
        "sections.*",
        "sections.*.sample.*",
        "alerts[].*",
        "alert_taxonomy[].*",
        "alert_taxonomy[].correlation_keys[]",
        "correlation.*"
      ]
    },
    "summary": {
      "required_top_level": [
        "schema_version",
        "source_schema_version",
        "status",
        "generated_at",
        "source_generated_at",
        "summary",
        "section_statuses",
        "checklist",
        "top_alerts",
        "required_operator_actions",
        "alert_taxonomy",
        "operator_playbook_summary",
        "correlation",
        "correlation_ids"
      ],
      "required_summary_fields": [
        "overall_status",
        "p0_count",
        "p1_count",
        "info_count",
        "section_count",
        "blocking_section_count",
        "warning_section_count",
        "top_alert_count",
        "required_operator_action_count",
        "alert_taxonomy_count",
        "correlation_id_count",
        "read_only_input_count"
      ],
      "required_operator_playbook_summary_fields": [
        "item_count",
        "blocking_item_count",
        "manual_review_item_count",
        "observe_only_item_count",
        "items"
      ],
      "append_only_paths": [
        "summary.*",
        "section_statuses.*",
        "checklist[].*",
        "top_alerts[].*",
        "required_operator_actions[].*",
        "alert_taxonomy[].*",
        "alert_taxonomy[].correlation_keys[]",
        "operator_playbook_summary.*",
        "operator_playbook_summary.items[].*",
        "correlation.*",
        "correlation_ids[].*"
      ]
    },
    "validation": {
      "required_top_level": [
        "schema_version",
        "status",
        "generated_at",
        "summary",
        "artifacts",
        "findings"
      ],
      "required_summary_fields": [
        "artifact_count",
        "missing_artifact_count",
        "json_parse_error_count",
        "missing_required_field_count",
        "sensitive_marker_count",
        "finding_count"
      ],
      "append_only_paths": [
        "summary.*",
        "artifacts.*",
        "artifacts.*.missing_fields[]",
        "artifacts.*.missing_summary_fields[]",
        "artifacts.*.missing_nested_fields.*[]",
        "artifacts.*.missing_markers[]",
        "findings[].*"
      ]
    }
  },
  "markdown_required_markers": [
    "# Full Product Health",
    "**Status:**",
    "## Counts",
    "## Top Alerts",
    "## Operator Playbook Summary",
    "## Checklist",
    "## Artifact Paths",
    "## Skipped Sections"
  ]
}
